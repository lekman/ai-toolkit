{
  "permissions": {
    "defaultMode": "auto",
    "deny": [
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Read(**/credentials)",
      "Read(**/credentials.*)",
      "Read(**/*.pem)",
      "Read(**/*.key)",
      "Read(**/*.crt)",
      "Read(**/*.cert)",
      "Read(**/*.p12)",
      "Read(**/*.pfx)",
      "Read(**/*.jks)",
      "Read(**/*.keystore)",
      "Read(**/*.truststore)",

      "Write(**/.env)",
      "Write(**/.env.*)",
      "Edit(**/.env)",
      "Edit(**/.env.*)",
      "Write(**/credentials)",
      "Write(**/credentials.*)",
      "Edit(**/credentials)",
      "Edit(**/credentials.*)",
      "Write(**/*.pem)",
      "Edit(**/*.pem)",
      "Write(**/*.key)",
      "Edit(**/*.key)",
      "Write(**/*.p12)",
      "Edit(**/*.p12)",
      "Write(**/*.pfx)",
      "Edit(**/*.pfx)",
      "Write(**/*.jks)",
      "Edit(**/*.jks)",
      "Write(**/*.keystore)",
      "Edit(**/*.keystore)",
      "Write(**/*.truststore)",
      "Edit(**/*.truststore)",

      "Read(~/.ssh/**)",
      "Read(**/id_rsa)",
      "Read(**/id_ed25519)",
      "Read(~/.aws/**)",
      "Read(**/.aws/credentials*)",
      "Read(~/.azure/**)",
      "Read(~/.config/gcloud/**)",
      "Read(~/.kube/**)",
      "Read(**/.kube/config)",
      "Read(~/.docker/**)",
      "Read(~/.gnupg/**)",
      "Read(~/.npmrc)",
      "Read(~/.netrc)",

      "Write(~/.ssh/**)",
      "Edit(~/.ssh/**)",
      "Write(**/id_rsa)",
      "Edit(**/id_rsa)",
      "Write(**/id_ed25519)",
      "Edit(**/id_ed25519)",
      "Write(~/.aws/**)",
      "Edit(~/.aws/**)",
      "Write(~/.azure/**)",
      "Edit(~/.azure/**)",
      "Write(~/.config/gcloud/**)",
      "Edit(~/.config/gcloud/**)",
      "Write(~/.kube/**)",
      "Edit(~/.kube/**)",
      "Write(~/.docker/**)",
      "Edit(~/.docker/**)",
      "Write(~/.gnupg/**)",
      "Edit(~/.gnupg/**)",
      "Write(~/.npmrc)",
      "Edit(~/.npmrc)",
      "Write(~/.netrc)",
      "Edit(~/.netrc)",

      "Read(~/.claude/.credentials.json)",
      "Read(~/.claude/credentials.json)",
      "Read(~/.config/claude/**)",
      "Write(~/.claude/.credentials.json)",
      "Edit(~/.claude/.credentials.json)",
      "Write(~/.claude/credentials.json)",
      "Edit(~/.claude/credentials.json)",
      "Write(~/.config/claude/**)",
      "Edit(~/.config/claude/**)",
      "Write(~/.claude/settings.json)",
      "Edit(~/.claude/settings.json)",
      "Write(~/.claude/settings.local.json)",
      "Edit(~/.claude/settings.local.json)",
      "Write(**/.claude/settings.json)",
      "Edit(**/.claude/settings.json)",
      "Write(**/.claude/settings.local.json)",
      "Edit(**/.claude/settings.local.json)",

      "Bash(cat ~/.ssh/*)",
      "Bash(cat ~/.aws/*)",
      "Bash(cat ~/.gnupg/*)",
      "Bash(cat ~/.claude/*)",
      "Bash(cat /Users/*/.claude/*)",
      "Bash(cat $HOME/.claude/*)"
    ]
  }
}
